# ── Server ────────────────────────────────
PORT=8080

# ── Storage ───────────────────────────────
# Set to true for local dev (uses ./local-jobs/ mounted volume)
# Set to false for cloud deployment (GCS or S3)
USE_LOCAL_STORE=true
LOCAL_JOBS_DIR=/data/jobs

# Cloud storage (ignored when USE_LOCAL_STORE=true)
CLOUD_PROVIDER=gcp
GCS_BUCKET=pai-skills-jobs
S3_BUCKET=pai-skills-jobs
AWS_REGION=us-east-1

# ── Anthropic ─────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL=claude-opus-4-6
MAX_TOKENS=8192

# ── Auth ──────────────────────────────────
# Set false to disable auth (local dev / VPN deployment)
# Set true and configure Okta vars for production
AUTH_ENABLED=false
# OKTA_DOMAIN=company.okta.com
# OKTA_CLIENT_ID=0oa...
# OKTA_AUDIENCE=api://default

# ── Limits ────────────────────────────────
MAX_CONCURRENT_JOBS=10
MAX_JOB_DURATION_SECONDS=600
MAX_TOOL_CALLS_PER_JOB=50
MAX_UPLOAD_SIZE_MB=100
